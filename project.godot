; Engine configuration file.
; It is best edited using the Godot editor UI.

config_version=5

[application]

config/name="雨灯镇：第十三封来信"
run/main_scene="res://scenes/boot/Boot.tscn"
config/features=PackedStringArray("4.2")

[autoload]

GameState="*res://scripts/autoload/game_state.gd"
DataRegistry="*res://scripts/autoload/data_registry.gd"
AudioManager="*res://scripts/audio/audio_manager.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

textures/canvas_textures/default_texture_filter=0
